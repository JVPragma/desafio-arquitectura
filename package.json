{
"name": "investment-platform-architectures",
"version": "1.0.0",
"description": "Diseño y Aplicación de Arquitecturas Frontend - Plataforma de Gestión de Inversiones",
"main": "webpack.config.js",
"scripts": {
"install:all": "npm install && npm --prefix monolithic install && npm --prefix microfrontends/investment-manager install && npm --prefix microfrontends/dashboard install",
"build": "webpack --mode production",
"build:monolithic": "webpack --config monolithic/webpack.config.js --mode production",
"build:microfrontends": "webpack --config microfrontends/webpack.config.js --mode production",
"start": "webpack serve --mode development",
"dev": "webpack --watch --mode development"
},
"keywords": [
"react",
"typescript",
"monolithic",
"microfrontends",
"architecture"
],
"author": "Juan Carlos Vidal",
"license": "MIT",
"dependencies": {
"react": "^18.2.0",
"react-dom": "^18.2.0"
},
"devDependencies": {
"@types/react": "^18.2.0",
"@types/react-dom": "^18.2.0",
"css-loader": "^6.8.1",
"style-loader": "^3.3.3",
"ts-loader": "^9.4.2",
"typescript": "^5.1.6",
"webpack": "^5.88.0",
"webpack-cli": "^5.1.4",
"webpack-dev-server": "^4.15.1",
"tsconfig-paths-webpack-plugin": "^4.1.0"
}
}

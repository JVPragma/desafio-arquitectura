{
"compilerOptions": {
"target": "es2020",
"module": "esnext",
"lib": ["es2020", "dom", "dom.iterable"],
"jsx": "react-jsx",
"declaration": true,
"declarationMap": true,
"sourceMap": true,
"outDir": "./dist",
"rootDir": "./",
"strict": true,
"esModuleInterop": true,
"skipLibCheck": true,
"forceConsistentCasingInFileNames": true,
"resolveJsonModule": true,
"moduleResolution": "node",
"allowSyntheticDefaultImports": true,
"baseUrl": ".",
"paths": {
"@monolithic/": ["monolithic/src/"],
"@microfrontends/": ["microfrontends//src/*"],
"@shared/": ["shared/"]
}
},
"include": ["monolithic//", "microfrontends//", "comparative/*/"],
"exclude": ["node_modules", "dist", "build"]
}
